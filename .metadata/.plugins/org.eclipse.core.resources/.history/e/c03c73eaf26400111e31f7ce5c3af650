#include "stm32f1xx.h"
//led;  PA0, PA1, PA2
//botao: PB0, PB1, PB5

int main(void) {
    // habilitar clock  A e B
    RCC->APB2ENR |= (1 << 2) | (1 << 3);

    //led output
    GPIOA->CRL &= ~(0xFFF);  //limpa os 12 primeiros bits
    GPIOA->CRL |=  (0x222); //coloca 0010 (output) nos 3 primeiros blocos




    while(1) {
    	GPIOA->ODR |= 3;
    }
}
