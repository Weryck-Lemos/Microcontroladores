#include <stdint.h>
#include "stm32f1xx.h"

// Flag para avisar o loop principal que 1 segundo se passou
volatile uint8_t mudar_cor_flag = 0;
volatile uint8_t indice_cor = 0;

/* * Mapeamento dos pinos para o LED RGB (Anodo Comum ou Catodo Comum)
 * Assumindo: PA0 = Vermelho, PA1 = Verde, PA2 = Azul
 * * Binário: (Azul)(Verde)(Vermelho)
 */
const uint8_t sequencia_cores[8] = {
    0,  // 000 -> Apagado
    1,  // 001 -> Vermelho (PA0)
    2,  // 010 -> Verde    (PA1)
    4,  // 100 -> Azul     (PA2)
    3,  // 011 -> Amarelo  (Vermelho + Verde)
    6,  // 110 -> Ciano    (Verde + Azul)
    5,  // 101 -> Roxo     (Vermelho + Azul)
    7   // 111 -> Branco   (Vermelho + Verde + Azul)
};

// Interrupção do SysTick - Dispara a cada 1 segundo
void SysTick_Handler(void)
{
    mudar_cor_flag = 1;
}

int main(void)
{
    // 1. Habilita o clock para a Porta A (GPIOA)
    RCC->APB2ENR |= (1 << 2);

    // 2. Configura PA0, PA1 e PA2 como Saída Push-Pull (Velocidade 2MHz)
    GPIOA->CRL &= ~0xFFF; // Limpa as configurações anteriores dos 3 pinos
    GPIOA->CRL |= 0x222;  // Define modo Output para PA0, PA1 e PA2

    // Inicia com todos os pinos em nível baixo (0)
    GPIOA->ODR &= ~0x7;

    /* * 3. Configuração do SysTick para 1 Segundo
     * O clock padrão de inicialização interna do STM32F103 (HSI) é de 8 MHz.
     * Portanto, 8.000.000 de ciclos equivalem a exatamente 1 segundo.
     * * NOTA: Se os seus LEDs piscarem rápido demais, significa que sua placa
     * está configurada para 72MHz. Se isso acontecer, mude o número abaixo para 72000000.
     */
    if (SysTick_Config(8000000))
    {
        while (1); // Trava aqui se houver erro de estouro de bits (segurança)
    }

    while (1)
    {
        // Aguarda a interrupção do SysTick avisar que deu 1 segundo
        if (mudar_cor_flag)
        {
            mudar_cor_flag = 0; // Limpa a flag

            // Limpa os pinos PA0, PA1 e PA2 antes de aplicar a nova cor
            GPIOA->ODR = (GPIOA->ODR & ~0x7) | sequencia_cores[indice_cor];

            // Avança para a próxima cor da lista (vai de 0 a 7 e reinicia)
            indice_cor = (indice_cor + 1) % 8;
        }
    }
}
