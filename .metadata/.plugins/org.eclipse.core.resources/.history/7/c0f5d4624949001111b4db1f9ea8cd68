#include "stm32f1xx.h"

int main(void) {
    // 1. Habilitar o clock para as Portas A e B
    RCC->APB2ENR |= (1 << 2) | (1 << 3);

    // 2. Configurar PA0, PA1, PA2 como Saída (Push-Pull, 2MHz)
    // Limpa 12 bits (3 pinos x 4 bits) e define como 0x2
    GPIOA->CRL &= ~(0xFFF);
    GPIOA->CRL |=  (0x222);

    // 3. Configurar PB0, PB1 e PB5 como Entrada com Pull-up
    // Cada pino usa 4 bits. PB5 ocupa os bits 20-23 do CRL.
    // Vamos limpar os bits dos pinos 0, 1 e 5:
    GPIOB->CRL &= ~( (0xF << 0) | (0xF << 4) | (0xF << 20) );
    // E definir todos como 0x8 (Input with pull-up/down):
    GPIOB->CRL |=  ( (0x8 << 0) | (0x8 << 4) | (0x8 << 20) );

    // 4. Ativar o Pull-up (escrevendo 1 no ODR)
    GPIOB->ODR |= (1 << 0) | (1 << 1) | (1 << 5);

    while(1) {
        // Botão PB0 -> LED PA0
        if (!(GPIOB->IDR & (1 << 0))) {
            GPIOA->ODR |= (1 << 0);
        } else {
            GPIOA->ODR &= ~(1 << 0);
        }

        // Botão PB1 -> LED PA1
        if (!(GPIOB->IDR & (1 << 1))) {
            GPIOA->ODR |= (1 << 1);
        } else {
            GPIOA->ODR &= ~(1 << 1);
        }

        // Botão PB5 -> LED PA2
        if (!(GPIOB->IDR & (1 << 5))) {
            GPIOA->ODR |= (1 << 2);
        } else {
            GPIOA->ODR &= ~(1 << 2);
        }
    }
}
