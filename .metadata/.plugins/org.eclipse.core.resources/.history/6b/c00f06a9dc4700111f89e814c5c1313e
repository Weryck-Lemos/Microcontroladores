#include "stm32f1xx.h"
int main(void)
{
	RCC->APB2ENR |= (1 << 4); //Enable GPIOC Clock
	GPIOC->CRH &= 0xFF0FFFFF; //Set C13 as Output
	GPIOC->CRH |= 0x00200000;
	while(1) //Blink LED in Blue-Pill C13 pin
	{
		GPIOC->ODR &=~0x00002000;
		for(int i=0;i<100000;i++);/*Delay*/
		GPIOC->ODR |= 0x00002000;
		for(int i=0;i<100000;i++);/*Delay*/
	}
}
