#include "stm32f1xx.h"

volatile uint16_t adc_buffer[3] = {0, 0, 0};

void GPIO_Init(void)
{
    /* Configure GPIO */

    // Ativa o clock para o PORTA e PORTB
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_IOPBEN | RCC_APB2ENR_AFIOEN;

    // Configura PA0, PA1 e PA2 como entrada analógica (Bits em 0000)
    GPIOA->CRL &= ~0x00000FFF;

    // Configura PA6 e PA7 como Função Alternativa Output (PWM do TIM3)
    GPIOA->CRL &= ~0xFF000000;
    GPIOA->CRL |=  0xBB000000;

    // Configura PB0 como Função Alternativa Output (PWM do TIM3)
    GPIOB->CRL &= ~0x0000000F;
    GPIOB->CRL |=  0x0000000B;

    // Configura PB8 como saída de 2MHz para o LED de teste/debug
    GPIOB->CRH &= ~0x0000000F;
    GPIOB->CRH |=  0x00000002;
}

void DMA1_Init(void)
{
    /* Configure DMA1 Channel 1 para o ADC1 */

    // Ativa o clock do DMA1
    RCC->AHBENR |= RCC_AHBENR_DMA1EN;

    DMA1_Channel1->CPAR = (uint32_t)&(ADC1->DR);  // Origem: Registrador de dados do ADC
    DMA1_Channel1->CMAR = (uint32_t)adc_buffer;  // Destino: Nosso vetor na memória RAM
    DMA1_Channel1->CNDTR = 3;                     // Quantidade de canais a transferir

    // MSIZE = 16 bits, PSIZE = 16 bits, Incremento de memória ativo, Modo Circular ativo
    DMA1_Channel1->CCR = DMA_CCR_MSIZE_0 | DMA_CCR_PSIZE_0 | DMA_CCR_MINC | DMA_CCR_CIRC;

    // Ativa o canal do DMA
    DMA1_Channel1->CCR |= DMA_CCR_EN;
}

void ADC1_Init(void)
{
    /* Configure ADC1 em Modo Scan Contínuo com DMA */

    // Ativa o clock do ADC1
    RCC->APB2ENR |= RCC_APB2ENR_ADC1EN;

    // Define o comprimento do Scan para 3 conversões (Valor 2 no campo L)
    ADC1->SQR1 = (2UL << ADC_SQR1_L_Pos);

    // Define a sequência: SQ1 = Canal 0, SQ2 = Canal 1, SQ3 = Canal 2
    ADC1->SQR3 = (0UL << ADC_SQR3_SQ1_Pos) | (1UL << ADC_SQR3_SQ2_Pos) | (2UL << ADC_SQR3_SQ3_Pos);

    // Tempo de amostragem máximo para garantir estabilidade na leitura
    ADC1->SMPR2 = (7UL << ADC_SMPR2_SMP0_Pos) | (7UL << ADC_SMPR2_SMP1_Pos) | (7UL << ADC_SMPR2_SMP2_Pos);

    // Ativa o Modo Scan e direciona os dados para o DMA
    ADC1->CR1 |= ADC_CR1_SCAN;
    ADC1->CR2 |= RCC_ADC1ENR_ADC1EN | ADC_CR2_DMA | ADC_CR2_CONT;

    // Liga o periférico do ADC
    ADC1->CR2 |= ADC_CR2_ADON;

    // Pequeno atraso para estabilização do ADC antes do disparo
    for(volatile uint32_t i = 0; i < 1000; i++);

    // Dispara a primeira conversão por software (as próximas serão automáticas)
    ADC1->CR2 |= ADC_CR2_SWSTART;
}

void TIM3_PWM_Init(void)
{
    /* Configure Timer 3 para gerar PWM nos 3 canais */

    // Ativa o clock do Timer 3
    RCC->APB1ENR |= RCC_APB1ENR_TIM3EN;

    TIM3->ARR = 4095;
    TIM3->PSC = 0;

    // Configura os canais 1, 2 e 3 em modo PWM 1 com preload ativo
    TIM3->CCMR1 |= (6 << 4) | (6 << 12) | TIM_CCMR1_OC1PE | TIM_CCMR1_OC2PE;
    TIM3->CCMR2 |= (6 << 4) | TIM_CCMR2_OC3PE;

    // Ativa as saídas físicas dos canais 1, 2 e 3
    TIM3->CCER |= TIM_CCER_CC1E | TIM_CCER_CC2E | TIM_CCER_CC3E;

    // Inicializa e ativa o contador do Timer
    TIM3->EGR |= TIM_EGR_UG;
    TIM3->CR1 |= TIM_CR1_CEN;
}

int main(void)
{
    // Inicialização modularizada do sistema
    GPIO_Init();
    DMA1_Init();
    ADC1_Init();
    TIM3_PWM_Init();

//MAIN APPLICATION*************************************************************

    for(;;)
    {
        // A CPU atualiza os canais de PWM lendo direto da RAM atualizada pelo DMA
        TIM3->CCR1 = adc_buffer[0];
        TIM3->CCR2 = adc_buffer[1];
        TIM3->CCR3 = adc_buffer[2];

        // Rotina paralela idêntica à do professor para provar que a CPU NÃO está ocupada/travada
        for (volatile uint32_t i = 0; i < 100000; i++);
        GPIOB->ODR |= (1 << 8);

        for (volatile uint32_t i = 0; i < 100000; i++);
        GPIOB->ODR &= ~(1 << 8);
    }
}
