#include "stm32f1xx.h"

int main(void) {
    // 1. Habilitar o Clock para Porta A e Porta B
    RCC->APB2ENR |= (1 << 2) | (1 << 3);

    // 2. Configurar PA0, PA1 e PA2 como Saída (Push-Pull, 2MHz)
    GPIOA->CRL &= ~(0xFFF);
    GPIOA->CRL |=  (0x222);

    // 3. Configurar Entradas:
    // PB0 e PB1 estão no CRL (bits 0-7)
    GPIOB->CRL &= ~(0xFF);
    GPIOB->CRL |=  (0x88);

    // PB10 está no CRH (bits 8-11 do CRH controlam o pino 10)
    GPIOB->CRH &= ~(0xF << 8); // Limpa os bits do pino 10
    GPIOB->CRH |=  (0x8 << 8); // Define como entrada com Pull-up/down (0x8)

    // Ativar Pull-UP para PB0, PB1 e PB10
    GPIOB->ODR |= (1 << 0) | (1 << 1) | (1 << 10);

    while(1) {
        // Lógica do Botão 1 (PB0) -> LED 1 (PA0)
        if (!(GPIOB->IDR & (1 << 0))) {
            GPIOA->ODR |= (1 << 0);
        } else {
            GPIOA->ODR &= ~(1 << 0);
        }

        // Lógica do Botão 2 (PB1) -> LED 2 (PA1)
        if (!(GPIOB->IDR & (1 << 1))) {
            GPIOA->ODR |= (1 << 1);
        } else {
            GPIOA->ODR &= ~(1 << 1);
        }

        // Lógica do Botão 3 (PB10) -> LED 3 (PA2)
        if (!(GPIOB->IDR & (1 << 10))) { // Verifica o bit 10 do IDR
            GPIOA->ODR |= (1 << 2);      // Liga PA2
        } else {
            GPIOA->ODR &= ~(1 << 2);     // Desliga PA2
        }
    }
}
