#include "stm32f1xx.h"
//led;  PA0, PA1, PA2


int main(void) {
    RCC->APB2ENR |= (1 << 2);

    //led output
    GPIOA->CRL &= ~(0xFFF);  //limpa os 12 primeiros bits
    GPIOA->CRL |=  (0x222); //coloca 0010 (output) nos 3 primeiros blocos



    while(1) {

    	GPIOA->ODR |= 1;


    	GPIOA->ODR |= 2;


        GPIOA->ODR |= (1 << 2);
    }
}
