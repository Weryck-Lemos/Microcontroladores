#include "stm32f1xx.h"

volatile uint32_t ms_sticks = 0
volatile uint8_t cor = 0;

void SysTick_Handler(void);

int main(){
    RCC->APB2ENR |= (1 << 2);

    GPIO->CRL &= ~(0xFFF);
    GPIOA->CRL |= (0x222);

    SysTick->LOAD = 8000-1;
    SysTick->VAL = 0;

    SysTick->CTRL = (1<<2) | (1<<1) | (1<<0);

    while(1){
        if(ms_sticks >=1000){
            ms_ticks = 0;

            GPIOA->ODR &= ~(0x7);
            GPIOA->ODR |= (cor & 0x7);
            cor = (cor +1)%8;
        }
    }
}

void SysTick_Handler(void){
    ms_ticks++;
}