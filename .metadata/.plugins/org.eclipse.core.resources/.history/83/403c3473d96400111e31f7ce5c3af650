#include <stdint.h>
#include "stm32f1xx.h"

volatile int SysTick_TASK = 0;
volatile uint8_t cor = 0;

void SysTick_Handler(void)
{
    SysTick_TASK = 1;
}

int main(void)
{
    // 1. Habilita o clock do GPIOA
    RCC->APB2ENR |= (1 << 2);

    // 2. Configura PA0, PA1 e PA2 como Output Push-Pull (2MHz)
    GPIOA->CRL &= ~0xFFF;
    GPIOA->CRL |= 0x222;
    GPIOA->ODR &= ~(0x7);

    // 3. Configura o SysTick para 1 segundo de forma dinâmica
    // SystemCoreClock armazena a frequência atual do sistema (ex: 8000000 ou 72000000)
    uint32_t ticks = SystemCoreClock;

    if ((ticks - 1UL) <= 0xFFFFFFUL)
    {
        SysTick->LOAD = (uint32_t)(ticks - 1UL);
        SysTick->VAL  = 0UL;

        // CORREÇÃO AQUI: (1 << 2) para usar o clock interno correto
        SysTick->CTRL = (1 << 2) |    // Fonte de clock: AHB interno
                        (1 << 1) |    // Habilita a interrupção
                        (1 << 0);     // Liga o SysTick
    }

    while(1)
    {
        if(SysTick_TASK)
        {
            SysTick_TASK = 0; // Reseta a flag

            // Atualiza os pinos PA0, PA1 e PA2 de forma limpa
            GPIOA->ODR = (GPIOA->ODR & ~0x7) | (cor & 0x7);
            
            cor = (cor + 1) % 8; // Próxima cor (0 a 7)
        }
    }
}
