#include "stm32f1xx.h"

// Função auxiliar para ler um canal específico do ADC de forma manual (Polling)
uint16_t Ler_ADC(uint8_t canal)
{
    ADC1->SQR3 = canal;                   // Escolhe qual canal (pino) vai ser lido agora
    ADC1->CR2 |= ADC_CR2_SWSTART;         // Dispara a conversão
    while(!(ADC1->SR & ADC_SR_EOC));      // Fica travado aqui esperando o ADC terminar (Espera Ocupada)
    return ADC1->DR;                      // Retorna o valor lido (0 a 4095)
}

void Hardware_Init(void)
{
    // 1. Liga os Clocks
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_IOPBEN | RCC_APB2ENR_AFIOEN | RCC_APB2ENR_ADC1EN;
    RCC->APB1ENR |= RCC_APB1ENR_TIM3EN;

    // 2. Configura Pinos
    GPIOA->CRL &= ~0x00000FFF;  // PA0, PA1, PA2 como Entrada Analógica
    GPIOA->CRL &= ~0xFF000000;
    GPIOA->CRL |=  0xBB000000;  // PA6, PA7 como Saída PWM
    GPIOB->CRL &= ~0x0000000F;
    GPIOB->CRL |=  0x0000000B;  // PB0 como Saída PWM

    // 3. Configura o ADC (O mais básico possível)
    ADC1->CR2 |= (7UL << ADC_CR2_EXTSEL_Pos); // Gatilho por software
    ADC1->CR2 |= ADC_CR2_ADON;                // Liga o ADC
    for(volatile int i=0; i<1000; i++);       // Espera o ADC aquecer
    ADC1->CR2 |= ADC_CR2_CAL;                 // Pede pro ADC se calibrar
    while(ADC1->CR2 & ADC_CR2_CAL);           // Espera a calibração terminar

    // 4. Configura o Timer 3 para o PWM (Idêntico ao seu)
    TIM3->ARR = 4095;
    TIM3->PSC = 0;
    TIM3->CCMR1 |= (6 << 4) | (6 << 12) | TIM_CCMR1_OC1PE | TIM_CCMR1_OC2PE;
    TIM3->CCMR2 |= (6 << 4) | TIM_CCMR2_OC3PE;
    TIM3->CCER |= TIM_CCER_CC1E | TIM_CCER_CC2E | TIM_CCER_CC3E;
    TIM3->EGR |= TIM_EGR_UG;
    TIM3->CR1 |= TIM_CR1_CEN;
}

int main(void)
{
    Hardware_Init();

    while(1)
    {
        // Lê os potenciômetros um por um e joga direto nas cores do LED
        TIM3->CCR1 = Ler_ADC(0); // PA0 controla o Vermelho
        TIM3->CCR2 = Ler_ADC(1); // PA1 controla o Verde
        TIM3->CCR3 = Ler_ADC(2); // PA2 controla o Azul

        // Um pequeno delay só para não inundar o hardware de requisições absurdamente rápido
        for(volatile int i=0; i<10000; i++);
    }
}
