#include "stm32f1xx.h"

int main(void) {
    // 1. Habilitar o Clock para Porta A e Porta B
    // RCC->APB2ENR: Bit 2 é porta A, Bit 3 é porta B
    RCC->APB2ENR |= (1 << 2) | (1 << 3);

    // 2. Configurar PA0, PA1 e PA2 como Saída (Push-Pull, 2MHz)
    // Cada pino usa 4 bits no registrador CRL.
    GPIOA->CRL &= ~(0xFFF);    // Limpa os primeiros 12 bits (pinos 0, 1 e 2)
    GPIOA->CRL |=  (0x222);    // Define como saída digital (0x2 = Output 2MHz)

    // 3. Configurar PB0, PB1 e PB2 como Entrada com Pull-up/down
    // Limpamos os bits e definimos como entrada (0x8 = Input with pull-up/down)
    GPIOB->CRL &= ~(0xFFF);
    GPIOB->CRL |=  (0x888);

    // Para ser Pull-UP (repouso em 1), precisamos colocar 1 no registrador ODR
    GPIOB->ODR |= (1 << 0) | (1 << 1) | (1 << 2);

    while(1) {
        // Lógica do Botão 1 -> LED 1
        // Verificamos o registrador IDR (Input Data Register)
        if (!(GPIOB->IDR & (1 << 0))) { // Se pino PB0 for 0 (apertado)
            GPIOA->ODR |= (1 << 0);     // Liga PA0
        } else {
            GPIOA->ODR &= ~(1 << 0);    // Desliga PA0
        }

        // Lógica do Botão 2 -> LED 2
        if (!(GPIOB->IDR & (1 << 1))) {
            GPIOA->ODR |= (1 << 1);
        } else {
            GPIOA->ODR &= ~(1 << 1);
        }

        // Lógica do Botão 3 -> LED 3
        if (!(GPIOB->IDR & (1 << 2))) {
            GPIOA->ODR |= (1 << 2);
        } else {
            GPIOA->ODR &= ~(1 << 2);
        }
    }
}
