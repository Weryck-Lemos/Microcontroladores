#include <stdint.h>
#include "stm32f1xx.h"

volatile int SysTick_TASK = 0;
volatile uint8_t cor = 0;

void SysTick_Handler(void)
{
    SysTick_TASK = 1;
}

int main(void)
{
    RCC->APB2ENR |= (1<< 2);

    GPIOA->CRL &= ~0xFFF;
    GPIOA->CRL |= 0x222;
    GPIOA->ODR &= ~(0x7);

    uint32_t ticks = 1000000; // 1000000 ciclos = 1 seg

    if ((ticks - 1UL) <= 0xFFFFFFUL)
    {
        SysTick->LOAD =(uint32_t)(ticks - 1UL);

        SysTick->VAL = 0UL;

        SysTick->CTRL  = (1 << 2) |     //clock do SysTick
                         (1 << 1) |    //babilita a interrupção do sysTick
                         (1 << 0);      //liga o temporizador
    }

    while(1)
    {

        if(SysTick_TASK)
        {
            SysTick_TASK = 0; // reseta a flag

            
            GPIOA->ODR &= ~(0x7); // limpa a cor anterior apagando
            GPIOA->ODR |= (cor & 0x7); //nova combinação de cores
            cor = (cor + 1) % 8;
        }
    }
}
